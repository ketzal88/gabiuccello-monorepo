# ============================================
# Firebase — cliente (browser)
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================================
# Firebase Admin — server-side (webhook)
# ============================================
# Service account → Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================
# Stripe
# ============================================
# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → tu endpoint → "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_xxx

# API secret key — Stripe Dashboard → Developers → API keys → "Reveal live key"
# Usada por el webhook para detectar qué producto se compró (libro / bundle / upgrade)
STRIPE_SECRET_KEY=sk_live_xxx

# Opcional: override del Payment Link de upgrade (default hardcodeado en src/lib/upgrade-url.ts)
# NEXT_PUBLIC_STRIPE_LINK_UPGRADE=https://buy.stripe.com/xxx

# ============================================
# Meta CAPI (Conversions API)
# ============================================
META_PIXEL_ID=1234567890
META_CAPI_ACCESS_TOKEN=EAAxxxx

# ============================================
# Resend (emails transaccionales)
# ============================================
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hola@tudominio.com

# ============================================
# Slack (notificaciones de ventas, opcional)
# ============================================
# SLACK_BOT_TOKEN=xoxb-xxx
# SLACK_ERROR_CHANNEL_ID=C0XXXXXX
